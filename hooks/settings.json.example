{
  "_comment": "Example .claude/settings.json wiring for the playbook hooks. Place at .claude/settings.json in the project (NOT in the worktree, in main checkout — committed). Adjust paths to your install location.",

  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/stop-hook-checks.sh",
            "timeout": 120000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-dangerous-commands.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  },

  "permissions": {
    "allow": [
      "Bash(pnpm checks)",
      "Bash(pnpm test)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm lint)",
      "Bash(pnpm build)",
      "Bash(pnpm dev:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git fetch:*)",
      "Bash(git worktree list)",
      "Bash(git worktree add:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)"
    ]
  }
}
